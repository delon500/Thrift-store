# Copy to backend/.env and fill in real values. backend/.env is git-ignored.

# ── Core ────────────────────────────────────────────────────────────────────
PORT=5000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/new_thrift
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated browser origins allowed to call the API (CORS allowlist).
# Defaults to the three local dev apps if unset.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Optional. Integration tests (npm run test:integration) run against a throwaway
# database, derived from DATABASE_URL (db name -> thriftstore_test) unless set here.
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/thriftstore_test

# ── Cloudinary (product image hosting) ──────────────────────────────────────
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_SECRET_KEY=your-api-secret

# ── OpenAI (product image analysis) ─────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── PayFast (payments, ZAR) ─────────────────────────────────────────────────
# PayFast starts in sandbox mode. Switch to live only after account approval,
# production webhooks, and real-payment checks are complete.
PAYFAST_MODE=sandbox
PAYFAST_MERCHANT_ID=your-payfast-merchant-id
PAYFAST_MERCHANT_KEY=your-payfast-merchant-key
PAYFAST_PASSPHRASE=your-payfast-passphrase-if-enabled

# PayFast ITN must be reachable from the internet. For local sandbox testing,
# point this at an ngrok / Cloudflare Tunnel URL (see the run instructions).
# Setting either is enough — PAYFAST_NOTIFY_URL takes precedence; otherwise the
# notify path is appended to API_PUBLIC_URL automatically.
API_PUBLIC_URL=https://your-tunnel-url.example
PAYFAST_NOTIFY_URL=https://your-tunnel-url.example/api/payments/payfast/itn

# Where the customer is redirected after paying. This is a browser redirect, so
# localhost is fine. NOTE: this is the CUSTOMER frontend (5173), where /checkout
# lives — not the admin app (5174).
FRONTEND_URL=http://localhost:5173

# ── Email (approval + order notifications, via SMTP) ────────────────────────
# Optional. If these are unset, the action still works and the email is logged
# to the server console instead of sent. Verify with: npm run mail:test [addr].
# Gmail: enable 2-Step Verification, then use a 16-char App Password (no spaces)
# as SMTP_PASS. Port 587 uses STARTTLS; use 465 (SSL) if 587 is blocked on your
# network — the service switches to secure mode automatically for port 465.
APP_NAME=School Thrift
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ── Dev-only escape hatch ───────────────────────────────────────────────────
# Set to "true" to enable POST /api/payments/confirm, which marks an order paid
# by hand WITHOUT a real ITN (useful before a tunnel is set up). Keep it
# unset/false once the PayFast ITN reaches your backend; never enable in prod.
ALLOW_MANUAL_PAYMENT_CONFIRMATION=false
